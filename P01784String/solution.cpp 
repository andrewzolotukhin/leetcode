class Solution {
public:
    bool checkOnesSegment(string s) {
        int l = -1, r = -1, n = s.size();
        for (int i = 0; i < n; i++) {
            if (s[i] == '1') {
                l = i;
                break;
            }
        }
        if (l == -1)
            return true;
        for (int i = n - 1; i >= l; i--) {
            if (s[i] == '1') {
                r = i;
                break;
            }
        }
        for (int i = l; i <= r; i++) {
            if (s[i] == '0')
                return false;
        }
        return true;
    }
};