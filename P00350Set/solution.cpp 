class Solution {
public:
    vector<int> intersect(vector<int>& nums1, vector<int>& nums2) {
        multiset<int> s1(nums1.begin(), nums1.end()), s2(nums2.begin(), nums2.end());
        vector<int> ans;
        for(const auto& k: s2) {
            if(s1.count(k)) {
                int c = min(s1.count(k), s2.count(k));
                for(int i  = 0; i  < c; i ++){
                  ans.push_back(k);
                }
                s1.erase(k);
            }
        }
        return ans;
    }
};